<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FoxPlayer" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/fox_accent</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/fox_surface2</item>
        <item name="colorSecondary">@color/fox_accent2</item>
        <item name="colorSurface">@color/fox_surface</item>
        <item name="colorOnSurface">@color/fox_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/fox_text_secondary</item>
        <item name="colorOutline">@color/fox_divider</item>
        <item name="android:colorBackground">@color/fox_background</item>
        <item name="android:statusBarColor">@color/fox_background</item>
        <item name="android:navigationBarColor">@color/fox_background</item>
        <item name="android:windowBackground">@color/fox_background</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
    </style>

    <style name="Theme.FoxPlayer.Player" parent="Theme.FoxPlayer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="FoxCardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/fox_card</item>
        <item name="cardCornerRadius">10dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="strokeColor">@color/fox_divider</item>
    </style>

    <style name="FoxChip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/fox_chip_bg</item>
        <item name="chipStrokeColor">@color/fox_divider</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/fox_text_secondary</item>
        <item name="chipCornerRadius">18dp</item>
    </style>

    <style name="FoxChip.Selected">
        <item name="chipBackgroundColor">@color/fox_chip_selected</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="WindowAnimation">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
        <item name="android:fragmentOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:fragmentOpenExitAnimation">@anim/fade_out</item>
        <item name="android:fragmentCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:fragmentCloseExitAnimation">@anim/fade_out</item>
    </style>
</resources>