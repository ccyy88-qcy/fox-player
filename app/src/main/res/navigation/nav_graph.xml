<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment android:id="@+id/homeFragment"
        android:name="com.foxplayer.ui.home.HomeFragment"
        android:label="@string/home">
        <action android:id="@+id/action_home_to_player"
            app:destination="@id/playerFragment" />
        <action android:id="@+id/action_home_to_detail"
            app:destination="@id/detailFragment" />
        <action android:id="@+id/action_home_to_live"
            app:destination="@id/liveFragment" />
        <action android:id="@+id/action_home_to_search"
            app:destination="@id/searchFragment" />
    </fragment>

    <fragment android:id="@+id/searchFragment"
        android:name="com.foxplayer.ui.search.SearchFragment"
        android:label="@string/search">
        <action android:id="@+id/action_search_to_player"
            app:destination="@id/playerFragment" />
        <action android:id="@+id/action_search_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment android:id="@+id/liveFragment"
        android:name="com.foxplayer.ui.live.LiveFragment"
        android:label="@string/live">
        <action android:id="@+id/action_live_to_player"
            app:destination="@id/playerFragment" />
    </fragment>

    <fragment android:id="@+id/favoriteFragment"
        android:name="com.foxplayer.ui.favorite.FavoriteFragment"
        android:label="@string/favorite">
        <action android:id="@+id/action_favorite_to_detail"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment android:id="@+id/settingsFragment"
        android:name="com.foxplayer.ui.settings.SettingsFragment"
        android:label="@string/settings" />

    <fragment android:id="@+id/detailFragment"
        android:name="com.foxplayer.ui.detail.DetailFragment"
        android:label="详情" />

    <fragment android:id="@+id/playerFragment"
        android:name="com.foxplayer.ui.player.PlayerFragment"
        android:label="Player">
        <argument android:name="videoId" app:argType="string" />
        <argument android:name="videoTitle" app:argType="string" />
        <argument android:name="videoCover" app:argType="string" android:defaultValue="" />
    </fragment>

</navigation>
