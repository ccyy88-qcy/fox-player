<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fox_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 大封面 + 渐变遮罩 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/ivDetailCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- 底部渐变 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_gravity="bottom"
                android:background="@drawable/gradient_cover" />
        </FrameLayout>

        <!-- 内容区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:layout_marginTop="-20dp">

            <!-- 标题 -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/fox_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- 年份·地区·类型 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <TextView android:id="@+id/tvDetailYear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/fox_text_hint" android:textSize="13sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" · " android:textColor="@color/fox_divider" android:textSize="13sp" />
                <TextView android:id="@+id/tvDetailArea" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/fox_text_hint" android:textSize="13sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" · " android:textColor="@color/fox_divider" android:textSize="13sp" />
                <TextView android:id="@+id/tvDetailType" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/fox_text_hint" android:textSize="13sp" />
            </LinearLayout>

            <!-- 评分 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">
                <LinearLayout android:id="@+id/layoutDetailStars" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" />
                <TextView android:id="@+id/tvDetailRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/fox_accent" android:textSize="15sp" android:textStyle="bold" android:layout_marginStart="4dp" />
            </LinearLayout>

            <!-- 当前播放源 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:background="@color/fox_surface2"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前源："
                    android:textColor="@color/fox_text_hint"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/tvCurrentSource"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/fox_accent"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnSwitchSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="切换源 ▶"
                    android:textColor="@color/fox_blue"
                    android:textSize="12sp"
                    android:padding="6dp"
                    android:background="@color/fox_surface3"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- 演员/简介 -->
            <TextView
                android:id="@+id/tvDetailActors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/fox_text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/fox_text_hint"
                android:textSize="13sp"
                android:maxLines="4"
                android:ellipsize="end"
                android:layout_marginTop="6dp"
                android:lineSpacingExtra="3dp" />

            <TextView
                android:id="@+id/tvExpandDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="展开 ▼"
                android:textColor="@color/fox_accent"
                android:textSize="12sp"
                android:layout_gravity="end"
                android:layout_marginTop="2dp" />

            <!-- 选集 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选集"
                android:textColor="@color/fox_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvEpisodes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- 底部操作栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@color/fox_surface"
            android:paddingHorizontal="8dp"
            android:elevation="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFavorite"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="⭐收藏"
                android:textColor="@color/fox_text_secondary"
                android:textSize="11sp"
                app:strokeColor="@color/fox_divider"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShare"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="↗分享"
                android:textColor="@color/fox_text_secondary"
                android:textSize="11sp"
                app:strokeColor="@color/fox_divider"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPip"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="📌小窗"
                android:textColor="@color/fox_text_secondary"
                android:textSize="11sp"
                app:strokeColor="@color/fox_divider"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSourceMenu"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🔀换源"
                android:textColor="@color/fox_blue"
                android:textSize="11sp"
                app:strokeColor="@color/fox_blue"
                android:layout_marginEnd="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="▶ 播放"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                app:backgroundTint="@color/fox_accent"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
